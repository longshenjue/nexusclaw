# Copy to .env.dev or .env.sandbox and fill in the values.
# Generate SECRET_KEY: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Generate FERNET_KEY: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

APP_ENV=dev   # dev | sandbox

# Application
SECRET_KEY=change-this
FERNET_KEY=change-this

# Database
# dev:     postgresql+asyncpg://postgres:postgres@postgres:5432/nexusclaw
# sandbox: postgresql+asyncpg://postgres:postgres@postgres:5432/nexusclaw
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nexusclaw

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
